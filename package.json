{
  "name": "mupot",
  "version": "0.21.1",
  "private": false,
  "description": "Installable Cloudflare-native sovereign agent substrate (the pot).",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate:local": "wrangler d1 migrations apply mupot --local",
    "migrate:remote": "wrangler d1 migrations apply mupot --remote",
    "update": "node scripts/mupot-update.mjs"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.14.5",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260601.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.0.0"
  },
  "license": "SEE LICENSE IN LICENSE.md"
}