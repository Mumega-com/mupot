FROM node:22.22.0-alpine3.22

LABEL org.opencontainers.image.title="Mupot Agent Host"
LABEL org.opencontainers.image.description="Credential-free base runtime for Mupot host adapters"

RUN addgroup -g 10001 -S mupot \
    && adduser -u 10001 -S -D -H -G mupot mupot \
    && mkdir -p /opt/mupot /var/lib/mupot/state \
    && chown -R 10001:10001 /var/lib/mupot

COPY --chown=10001:10001 fleet-runtime/*.mjs /opt/mupot/

USER 10001:10001
WORKDIR /var/lib/mupot

EXPOSE 8080
ENTRYPOINT ["/usr/local/bin/node", "/opt/mupot/container-entrypoint.mjs"]
