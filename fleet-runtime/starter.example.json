{
  "version": 1,
  "tenant": "customer-pot",
  "base_url": "https://pot.customer.example",
  "service_manager": "auto",
  "agents": [
    {
      "agent_id": "manager",
      "runtime": "hermes",
      "probe": "pgrep -f hermes",
      "handler": "node ~/.fleet/handlers/hermes.mjs"
    },
    {
      "agent_id": "builder",
      "runtime": "codex",
      "probe": "pgrep -f codex",
      "handler": "node ~/.fleet/handlers/codex.mjs"
    }
  ],
  "control_consumer_agent_id": "manager",
  "profiles": [
    {
      "schema": "mupot.agent-profile/v1",
      "agent_id": "manager",
      "adapter": "hermes",
      "command": ["/usr/local/bin/hermes", "chat", "--toolsets", "mupot"],
      "allowed_senders": ["builder"],
      "run_for": ["request"],
      "timeout_ms": 120000
    },
    {
      "schema": "mupot.agent-profile/v1",
      "agent_id": "builder",
      "adapter": "codex",
      "command": ["/usr/local/bin/codex", "exec"],
      "allowed_senders": ["manager"],
      "run_for": ["request", "message"],
      "timeout_ms": 120000
    }
  ]
}
