{
  "_comment": "Inbox handler config. Replace executable paths and welded identities. Productized profiles use argv arrays, reject unauthorized senders and acknowledgement loops, and persist each message before activation.",
  "spool_dir": "~/.fleet/inbox",
  "command_timeout_ms": 120000,
  "agents": [
    {
      "agent_id": "agent-one",
      "profile": {
        "schema": "mupot.agent-profile/v1",
        "agent_id": "agent-one",
        "adapter": "hermes",
        "command": ["/usr/local/bin/hermes", "chat", "--toolsets", "mupot"],
        "allowed_senders": ["agent-two"],
        "run_for": ["request"],
        "timeout_ms": 120000
      }
    },
    {
      "agent_id": "agent-two",
      "profile": {
        "schema": "mupot.agent-profile/v1",
        "agent_id": "agent-two",
        "adapter": "codex",
        "command": ["/usr/local/bin/codex", "exec"],
        "allowed_senders": ["agent-one"],
        "run_for": ["request", "message"],
        "timeout_ms": 120000
      }
    }
  ]
}
